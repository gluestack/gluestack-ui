# ─── Required ──────────────────────────────────────────────────
# At least one AI provider must be configured

# OpenAI API key (required for openai provider and image generation)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── LiteLLM / vLLM / Gemma ───────────────────────────────────
# Self-hosted AI via LiteLLM proxy pointing to vLLM
# Run: litellm --model vllm/gemma4-26b --port 4000
# Or point to a remote LiteLLM/vLLM server

LITELLM_BASE_URL=https://ai.geekyants.com
LITELLM_API_KEY=sk-***

# ─── Optional ──────────────────────────────────────────────────

# Default AI provider: 'openai', 'anthropic', or 'litellm'
BLOG_CLI_PROVIDER=litellm

# Default model for chosen provider
# For litellm: use the model name as registered in your LiteLLM config
BLOG_CLI_MODEL=vllm/gemma4-26b

# Image generation model (only OpenAI DALL-E supported; use --skip-image if unavailable)
# BLOG_CLI_IMAGE_MODEL=dall-e-3

# Default author name (must match a known author)
# BLOG_CLI_DEFAULT_AUTHOR_NAME=Sanchit Kumar

# Path to the website directory (relative to monorepo root)
# BLOG_CLI_WEBSITE_DIR=apps/website

# Slack webhook URL for pipeline failure notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...