# ─── Required ──────────────────────────────────────────────────
# At least one AI provider API key is required

# OpenAI API key (required for openai provider and image generation)
OPENAI_API_KEY=sk-...

# Anthropic API key (required for anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ──────────────────────────────────────────────────

# Default AI provider: 'openai' or 'anthropic'
# BLOG_CLI_PROVIDER=openai

# Default model for chosen provider
# BLOG_CLI_MODEL=gpt-4o

# Image generation model (only OpenAI supported)
# BLOG_CLI_IMAGE_MODEL=dall-e-3

# Default author name (must match a known author)
# BLOG_CLI_DEFAULT_AUTHOR_NAME=Sanchit Kumar

# Path to the website directory (relative to monorepo root)
# BLOG_CLI_WEBSITE_DIR=apps/website

# Slack webhook URL for pipeline failure notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...