# ─── Slack ────────────────────────────────────────────────────
# Bot token with conversations.history scope
SLACK_BOT_TOKEN=xoxb-...

# Channel ID to fetch messages from
SLACK_CHANNEL_ID=C0123456789

# ─── GitHub ───────────────────────────────────────────────────
# Personal access token with repo read access
GITHUB_TOKEN=ghp_...

