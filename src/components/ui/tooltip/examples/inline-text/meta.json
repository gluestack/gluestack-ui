{
  "title": "Inline Text",
  "description": "Tooltip anchored to inline text elements using long press interaction",
  "argTypes": {
    "placement": {
      "control": {
        "type": "select"
      },
      "options": [
        "top",
        "top left",
        "top right",
        "bottom",
        "bottom left",
        "bottom right",
        "left",
        "left top",
        "left bottom",
        "right",
        "right top",
        "right bottom"
      ],
      "defaultValue": "top"
    }
  },
  "reactLive": {
    "Tooltip": "@/components/ui/tooltip",
    "TooltipContent": "@/components/ui/tooltip",
    "TooltipText": "@/components/ui/tooltip",
    "Text": "@/components/ui/text"
  }
}
